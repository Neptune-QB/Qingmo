root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
indent_size = 4
max_line_length = 120
# animateFloat 是扩展函数需显式导入，ktlint 会误删
ktlint_disabled_rules = no-unused-imports

[*.{xml,json}]
indent_size = 4

[*.md]
trim_trailing_whitespace = false
